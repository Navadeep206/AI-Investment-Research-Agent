datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Analysis {
  id                   String   @id @default(cuid())
  company              String
  industry             String?
  marketCap            String?
  overallScore         Int?
  recommendation       String?
  confidence           Int?
  sourcesUsed          Int?
  evidenceQualityScore Int?
  research             Json
  scorecard            Json
  challenge            Json
  finalDecision        Json
  freshnessScore       Int?
  evidenceAgeMinutes   Int?
  recommendationReasonCodes Json?
  materialEventCount   Int?
  lastMaterialEventAt  DateTime?
  requestId            String?
  confidenceBreakdown  Json?
  agentMetrics         Json?
  createdAt            DateTime @default(now())
}
